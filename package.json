{
  "name": "projscan",
  "version": "0.1.3",
  "description": "Instant codebase insights — doctor, x-ray, and architecture map for any repository",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "projscan": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "prepare": "npm run build"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "codebase-analysis",
    "project-health",
    "architecture",
    "linting",
    "devtools",
    "code-quality",
    "analyzer",
    "project-scanner",
    "dev-tools",
    "dx"
  ],
  "author": "Abhi Yoheswaran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhiyoheswaran1/devlens.git"
  },
  "homepage": "https://github.com/abhiyoheswaran1/devlens#readme",
  "bugs": {
    "url": "https://github.com/abhiyoheswaran1/devlens/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.0.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.0"
  }
}
