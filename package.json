{
  "name": "projscan",
  "version": "0.10.0",
  "description": "Agent-first code intelligence. MCP server (2025-03-26) with AST parsing for JavaScript, TypeScript, and Python; code graph, BM25 + optional semantic search, cursor pagination, progress notifications, and context-budgeted output. CLI on the side.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "projscan": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-wasm.mjs",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "prepare": "npm run build"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "codebase-analysis",
    "project-health",
    "architecture",
    "linting",
    "devtools",
    "code-quality",
    "analyzer",
    "project-scanner",
    "dev-tools",
    "dx",
    "python",
    "tree-sitter",
    "multi-language"
  ],
  "author": "Abhi Yoheswaran",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/abhiyoheswaran1/projscan.git"
  },
  "homepage": "https://github.com/abhiyoheswaran1/projscan#readme",
  "bugs": {
    "url": "https://github.com/abhiyoheswaran1/projscan/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/types": "^7.29.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ora": "^8.1.0",
    "tree-sitter-python": "^0.25.0",
    "web-tree-sitter": "^0.26.8"
  },
  "peerDependencies": {
    "@xenova/transformers": "^2.17.0"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@xenova/transformers": "^2.17.0",
    "eslint": "^10.0.3",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.57.0",
    "vitest": "^2.1.0"
  }
}
